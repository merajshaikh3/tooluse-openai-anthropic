{
    "name": "nodejs-typescript-template",
    "version": "1.0.0",
    "description": "Template for a Node.js + Typescript backend project",
    "main": "index.js",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "dev": "nodemon src/server.ts",
        "build": "rm -rf dist && tsc",
        "start": "node dist/server.js",
        "clean": "rm -rf dist",
        "migration:generate": "npx ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/database/database.ts src/database/migrations/migrationName",
        "migration:run": "npx ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/database/database.ts",
        "migration:revert": "npx ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/database/database.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^17.4.1",
        "express": "^5.2.1",
        "express-validator": "^7.3.2",
        "helmet": "^8.1.0",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.2",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.2"
    }
}
